# 색인 차단 해제 플래그.
# 임시 *.vercel.app 운영 동안에는 설정하지 않음(기본 noindex).
# AdSense 승인 + logikitapps.com/wiki 연결 후에만 아래를 설정해 색인 허용:
# NEXT_PUBLIC_NOINDEX=false

# ── Supabase (인증 + 커뮤니티 + 서적/추천/퀴즈 데이터) ────────────────────────
# 대시보드 > Project Settings > API 에서 복사.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# service_role 키(서버 전용). AI 파이프라인 cron / prune cron 이 세션 없이
# 관리자 권한으로 books insert·job 갱신·조회수 정리에 사용한다.
# 퀴즈 채점(gradeQuiz)도 이 키로 정답을 읽는다 — anon/authenticated 롤에는
# quizzes.answer/explanation SELECT 권한이 없다(0008_hardening.sql). 미설정 시 채점 불가.
# ⚠️ 절대 NEXT_PUBLIC_ 접두어를 붙이지 말 것(브라우저 노출 금지).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# OAuth/비밀번호 재설정 등 redirect 의 절대 URL 베이스. basePath(/wiki) 포함.
#   로컬:   http://localhost:3000/wiki
#   운영:   https://logikitapps.com/wiki
# Supabase 대시보드 Auth > URL Configuration 의 Redirect URLs 에
#   <SITE_URL>/auth/callback, <SITE_URL>/update-password 을 등록하고
#   Auth > Providers 에서 Google 을 활성화해야 한다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000/wiki

# ── AI 콘텐츠 생성 (Claude / Anthropic) ─────────────────────────────────────
# https://console.anthropic.com/ 에서 발급. 서버 전용(브라우저 노출 금지).
# 대량 초안 = claude-haiku-4-5, 고품질 검수/재작성 = claude-opus-4-8.
ANTHROPIC_API_KEY=

# ── Keep-alive / Cron 보호 ─────────────────────────────────────────────────
# Vercel Cron 이 keep-alive·AI 생성·조회수 정리 엔드포인트를 호출할 때
# `Authorization: Bearer <값>` 을 자동 첨부하며, 엔드포인트는 이 토큰이 없는 호출을 401 로 거부한다.
# ⚠️ 운영(production)에서 비어 있으면 cron 엔드포인트는 모든 호출을 401 로 거부한다(fail-closed).
# 생성 예: `openssl rand -hex 32`
CRON_SECRET=
